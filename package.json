{
  "name": "routewatch",
  "version": "0.1.0",
  "description": "A lightweight CLI tool that monitors and visualizes Express/Fastify route usage and latency in real time.",
  "main": "dist/index.js",
  "bin": {
    "routewatch": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["express", "fastify", "monitoring", "cli", "routes", "latency"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  }
}
